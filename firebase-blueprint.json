{
  "entities": {
    "Config": {
      "title": "Global Config",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "currentPassword": {
          "type": "string",
          "description": "Master password for access"
        }
      },
      "required": ["currentPassword"]
    },
    "User": {
      "title": "User",
      "description": "User subscription and role information",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "subscriptionEndDate": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 date string for subscription end"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User role"
        }
      },
      "required": ["email", "subscriptionEndDate", "role"]
    }
  },
  "firestore": {
    "/config/globalConfig": {
      "schema": "Config",
      "description": "Global configuration document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    }
  }
}
