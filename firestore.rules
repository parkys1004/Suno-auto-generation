rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aimaster1004@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /config/globalConfig {
      // Anyone can read the config (to check password)
      // In a more secure app, we might restrict this, but AppGuard needs it.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own data
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Admin can do everything
      allow read, write: if isAdmin();
      
      // Allow querying by email for AppGuard (if authenticated)
      // Note: This might need a collection group rule or specific indexing
    }
    
    // Allow querying users collection by email
    match /users/{document=**} {
      allow list: if isAuthenticated();
    }
  }
}
